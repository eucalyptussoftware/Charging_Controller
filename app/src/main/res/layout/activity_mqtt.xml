<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1a1a2e"
    android:padding="24dp">

    <!-- Header -->
    <TextView
        android:id="@+id/tv_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="MQTT POWER MONITOR"
        android:textColor="#888888"
        android:textSize="48sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Connection Status -->
    <TextView
        android:id="@+id/tv_mqtt_status"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Disconnected"
        android:textColor="#FF5555"
        android:textSize="36sp"
        android:layout_marginTop="8dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_title" />

    <!-- Config Inputs -->
    <LinearLayout
        android:id="@+id/ll_config_inputs"
        android:layout_width="600dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="16dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_mqtt_status">

        <!-- Broker -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Broker URL"
            android:textColor="#cccccc"
            android:textSize="24sp"
            android:textStyle="bold"/>
        <EditText
            android:id="@+id/et_broker"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="ssl://..."
            android:textColor="#ffffff"
            android:textColorHint="#666666"
            android:textSize="32sp"
            android:inputType="textUri"
            android:minHeight="60dp"
            android:layout_marginBottom="16dp"/>

        <!-- Topic -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Topic"
            android:textColor="#cccccc"
            android:textSize="24sp"
            android:textStyle="bold"/>
        <EditText
            android:id="@+id/et_topic"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Topic"
            android:textColor="#ffffff"
            android:textColorHint="#666666"
            android:textSize="32sp"
            android:inputType="text"
            android:minHeight="60dp"
            android:layout_marginBottom="16dp"/>

        <!-- Username -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Username"
            android:textColor="#cccccc"
            android:textSize="24sp"
            android:textStyle="bold"/>
        <EditText
            android:id="@+id/et_username"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Username"
            android:textColor="#ffffff"
            android:textColorHint="#666666"
            android:textSize="32sp"
            android:inputType="text"
            android:minHeight="60dp"
            android:layout_marginBottom="16dp"/>

        <!-- Password -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Password"
            android:textColor="#cccccc"
            android:textSize="24sp"
            android:textStyle="bold"/>
        <EditText
            android:id="@+id/et_password"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Password"
            android:textColor="#ffffff"
            android:textColorHint="#666666"
            android:textSize="32sp"
            android:inputType="textPassword"
            android:minHeight="60dp"
            android:layout_marginBottom="8dp"/>

    </LinearLayout>

    <!-- QC / Connect Button -->
    <TextView
        android:id="@+id/btn_mqtt_connect"
        android:layout_width="160dp"
        android:layout_height="48dp"
        android:gravity="center"
        android:background="@drawable/cyan_button_bg"
        android:text="CONNECT"
        android:textColor="#ffffff"
        android:textStyle="bold"
        android:textSize="18sp"
        android:layout_marginTop="24dp"
        android:clickable="true"
        android:focusable="true"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/ll_config_inputs" />

    <!-- Power Display (using same style as Main) -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/btn_mqtt_connect"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="LIVE READING"
            android:textSize="20sp"
            android:textColor="#888888"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/tv_mqtt_power"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="-- W"
            android:textSize="200sp"
            android:textColor="#00d4ff"
            android:textStyle="bold"/>
            
    </LinearLayout>

    <!-- Back Button -->
    <TextView
        android:id="@+id/btn_back"
        android:layout_width="100dp"
        android:layout_height="48dp"
        android:gravity="center"
        android:background="@drawable/gray_button_bg"
        android:text="BACK"
        android:textColor="#ffffff"
        android:textStyle="bold"
        android:textSize="18sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
